# Server
PORT=3500

# Gemini API (for AI image generation - dev only)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Dev API route protection token
# If set, staging API routes require this token in x-dev-token header
DEV_API_TOKEN=

# Google Analytics (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# HubSpot
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=

# HubSpot Form IDs
NEXT_PUBLIC_HS_FORM_CONTACT=
NEXT_PUBLIC_HS_FORM_NEWSLETTER=
NEXT_PUBLIC_HS_FORM_ASSESSMENT=
